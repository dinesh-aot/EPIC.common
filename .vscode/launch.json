    "version": "0.2.0",
    "configurations": [
        {
            "name": "EPIC CRON - Extract Project (SUBMIT)",
            "type": "debugpy",
            "cwd": "${workspaceFolder}/jobs/epic-cron",
            "request": "launch",
            "program": "invoke_jobs.py",
            "args": ["SUBMIT", "v2"],
            "console": "integratedTerminal",
            "justMyCode": true,
            "envFile": "${workspaceFolder}/jobs/epic-cron/.env",
            "env": {
                "FLASK_ENV": "development",
                "PYTHONPATH": "${workspaceFolder}/jobs/epic-cron/src"
            }
        },
