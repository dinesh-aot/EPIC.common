# ==============================================================================
# EPIC CRON JOB - SAMPLE ENVIRONMENT VARIABLES
# ==============================================================================
# Copy this file to .env and update the values according to your environment
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATIONS
# ------------------------------------------------------------------------------

# TRACK Database (EPIC Track Application Database)
# Used for tracking environmental assessment projects
TRACK_DATABASE_USERNAME=app
TRACK_DATABASE_PASSWORD=your_track_db_password
TRACK_DATABASE_NAME=app
TRACK_DATABASE_HOST=localhost
TRACK_DATABASE_PORT=5432

# COMPLIANCE Database (Compliance Tracking Database)
# Used for compliance and monitoring data
COMPLIANCE_DATABASE_USERNAME=compliance
COMPLIANCE_DATABASE_PASSWORD=your_compliance_db_password
COMPLIANCE_DATABASE_NAME=compliance-db
COMPLIANCE_DATABASE_HOST=localhost
COMPLIANCE_DATABASE_PORT=5432

# SUBMIT Database (Submit Application Database)
# Main database for the Submit application
SUBMIT_DATABASE_USERNAME=admin
SUBMIT_DATABASE_PASSWORD=your_submit_db_password
SUBMIT_DATABASE_NAME=postgres
SUBMIT_DATABASE_HOST=localhost
SUBMIT_DATABASE_PORT=5432

# CONDITION Database (Condition Management Database)
# Used for managing environmental assessment conditions
CONDITION_DATABASE_USERNAME=condition
CONDITION_DATABASE_PASSWORD=your_condition_db_password
CONDITION_DATABASE_NAME=condition-db
CONDITION_DATABASE_HOST=localhost
CONDITION_DATABASE_PORT=5432

# CENTRE Database (Centre Application Database)
# Used for centre emailer and access request management
CENTRE_DATABASE_USERNAME=centre
CENTRE_DATABASE_PASSWORD=your_centre_db_password
CENTRE_DATABASE_NAME=centre-db
CENTRE_DATABASE_HOST=localhost
CENTRE_DATABASE_PORT=5432

# ------------------------------------------------------------------------------
# API CONFIGURATIONS
# ------------------------------------------------------------------------------

# CONDITION API Base URL
# Base URL for the Condition Management API
CONDITION_API_BASE_URL=http://localhost:5000

# EPIC Public Base URL
# Base URL for the BC EPIC Public API used to fetch published documents
EPIC_PUBLIC_BASE_URL=https://projects.eao.gov.bc.ca

# EPIC Public Document Type IDs (comma-separated)
# Filters document fetching to specific EPIC document types.
# Leave unset to use the keys from EPIC_PUBLIC_DOCUMENT_TYPE_ID_MAP (or the built-in defaults).
EPIC_PUBLIC_DOCUMENT_TYPE_IDS=

# EPIC Public Document Type ID Map (comma-separated epicId:conditionTypeId pairs)
# Maps EPIC Public type IDs to condition repo document_type_id values.
# Leave unset to use the built-in defaults in EpicPublicService.DEFAULT_DOCUMENT_TYPE_ID_MAP.
# Example: 5cf00c03a266b7e1877504d1:3
EPIC_PUBLIC_DOCUMENT_TYPE_ID_MAP=

# ------------------------------------------------------------------------------
# KEYCLOAK AUTHENTICATION
# ------------------------------------------------------------------------------

# Keycloak Base URL
# URL of the Keycloak authentication server
KEYCLOAK_BASE_URL=https://dev.loginproxy.gov.bc.ca

# Keycloak Realm Name
# The realm name in Keycloak (default: eao-epic)
KEYCLOAK_REALM_NAME=eao-epic

# Service Account Credentials
# Service account ID and secret for Keycloak admin API access
# Used for user management and group operations
SERVICE_ACCOUNT_ID=your_service_account_client_id
SERVICE_ACCOUNT_SECRET=your_service_account_client_secret

# Connection Timeout
# Timeout in seconds for HTTP requests (default: 60)
CONNECT_TIMEOUT=60

# ------------------------------------------------------------------------------
# JWT/OIDC CONFIGURATION
# ------------------------------------------------------------------------------

# JWT OIDC Well-Known Configuration URL
JWT_OIDC_WELL_KNOWN_CONFIG=https://dev.loginproxy.gov.bc.ca/auth/realms/eao-epic/.well-known/openid-configuration

# JWT OIDC Algorithms (default: RS256)
JWT_OIDC_ALGORITHMS=RS256

# JWT OIDC JWKS URI
JWT_OIDC_JWKS_URI=https://dev.loginproxy.gov.bc.ca/auth/realms/eao-epic/protocol/openid-connect/certs

# JWT OIDC Issuer
JWT_OIDC_ISSUER=https://dev.loginproxy.gov.bc.ca/auth/realms/eao-epic

# JWT OIDC Audience (default: account)
JWT_OIDC_AUDIENCE=account

# JWT OIDC Caching Enabled (default: True)
JWT_OIDC_CACHING_ENABLED=True

# ------------------------------------------------------------------------------
# CHES (Common Hosted Email Service) CONFIGURATION
# ------------------------------------------------------------------------------

# CHES Token Endpoint
# OAuth2 token endpoint for CHES authentication
CHES_TOKEN_ENDPOINT=https://dev.loginproxy.gov.bc.ca/auth/realms/comsvcauth/protocol/openid-connect/token

# CHES Client ID and Secret
# Client credentials for CHES API access
CHES_CLIENT_ID=your_ches_client_id
CHES_CLIENT_SECRET=your_ches_client_secret

# CHES Base URL
# Base URL for the Common Hosted Email Service API
CHES_BASE_URL=https://ches-dev.api.gov.bc.ca

# ------------------------------------------------------------------------------
# EMAIL CONFIGURATION
# ------------------------------------------------------------------------------

# Sender Email Address
# Email address used as the sender for all outgoing emails
SENDER_EMAIL=EAO.ManagementPlanSupport@gov.bc.ca

# Staff Support Email
# Email address for staff support inquiries
STAFF_SUPPORT_MAIL_ID=EAO.ManagementPlanSupport@gov.bc.ca

# ------------------------------------------------------------------------------
# WEB APPLICATION CONFIGURATION
# ------------------------------------------------------------------------------

# Web Application URL
# Base URL of the Submit web application
WEB_URL=https://dev.submit.eao.gov.bc.ca

# Signup URL Path
# Path for the proponent registration page (default: /proponent/registration)
SIGNUP_URL_PATH=/proponent/registration

# ------------------------------------------------------------------------------
# PENDING ACCESS REQUEST REMINDER CONFIGURATION
# ------------------------------------------------------------------------------

# Pending Access Reminder Hours
# Number of hours after which to send reminder for pending access requests (default: 48)
PENDING_ACCESS_REMINDER_HOURS=48

# Pending Access Reminder Email
# Email address to receive pending access request reminders
PENDING_ACCESS_REMINDER_EMAIL=admin@example.com

# Request Access Base URL
# Base URL for the request access application (Centre)
REQUEST_ACCESS_BASE_URL=http://localhost:5173

# ------------------------------------------------------------------------------
# CLAMAV ANTIVIRUS CONFIGURATION
# ------------------------------------------------------------------------------

# ClamAV Host
# Hostname or IP address of the ClamAV antivirus server
CLAMAV_HOST=localhost

# ClamAV Port
# Port number for ClamAV service (default: 3310)
CLAMAV_PORT=3310

# ------------------------------------------------------------------------------
# ENVIRONMENT SETTINGS
# ------------------------------------------------------------------------------

# Environment Name
# Current environment (development, testing, staging, production)
ENVIRONMENT=development
ENV_NAME=development

# ------------------------------------------------------------------------------
# SECURITY
# ------------------------------------------------------------------------------

# Secret Key
# Secret key for Flask application (generate a random string for production)
SECRET_KEY=your_secret_key_here_change_in_production
